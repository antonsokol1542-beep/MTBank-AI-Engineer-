# --- LLM Settings ---
# Рекомендуется: Groq (быстро, бесплатный tier): console.groq.com → API Keys
OPENAI_API_KEY=gsk_ВАШ_КЛЮЧ_СЮДА
OPENAI_API_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Альтернатива — OpenRouter (бесплатные модели): openrouter.ai → Keys
# OPENAI_API_KEY=sk-or-...
# OPENAI_API_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Альтернатива — OpenAI:
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# --- ASR Settings ---
WHISPER_MODEL=medium
# Device: "cpu" or "cuda"
WHISPER_DEVICE=cpu
# Compute type: "int8", "int8_float16", "float16", "float32"
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru

# --- Speaker Diarization (Optional) ---
# Get token at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=

# --- FastAPI Settings ---
API_HOST=0.0.0.0
API_PORT=8000

# --- OpenWebUI Pipelines ---
PIPELINES_API_KEY=0p3n-w3bu!

# --- OpenWebUI ---
OPENWEBUI_PORT=3000

# --- Logging ---
LOG_LEVEL=INFO
